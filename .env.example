# Deployed BountyCampaign contract address on Injective EVM
NEXT_PUBLIC_BOUNTY_CONTRACT_ADDRESS=

# Injective EVM RPC endpoint (default: public mainnet RPC)
NEXT_PUBLIC_INJECTIVE_RPC=https://k8s.global.mainnet.lcd.injective.network

# Injective EVM chain ID (default: 2525 for mainnet)
NEXT_PUBLIC_INJECTIVE_CHAIN_ID=2525

# WalletConnect Cloud project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
